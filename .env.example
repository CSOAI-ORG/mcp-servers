# MEOK AI Labs - Environment Configuration
# Copy this file to .env and fill in your values

# API Configuration
MEOK_API_KEY=your-api-key-here
API_VERSION=2.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://meok:password@localhost:5432/meokai
DB_PASSWORD=your-secure-password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your-redis-password

# Authentication
JWT_SECRET=your-very-secure-jwt-secret-key-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# CORS
CORS_ORIGINS=https://meok.ai,https://www.meok.ai

# External Services
OPENAI_API_KEY=your-openai-api-key

# Webhooks
MEOK_WEBHOOK_SECRET=your-webhook-secret

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=alerts@meok.ai

# Slack (for notifications)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# Monitoring
SENTRY_DSN=https://xxx@sentry.io/xxx
PROMETHEUS_ENABLED=true

# Grafana
GRAFANA_USER=admin
GRAFANA_PASSWORD=your-grafana-password

# Docker
DOCKER_REGISTRY=ghcr.io/meok-ai
