          "trust_service_criteria": {"type": "string"}
        },
        "required": ["system_name"]
      }
    },
    {
      "name": "nist_ai_rmf_assessment",
      "description": "NIST AI Risk Management Framework assessment",
      "input_schema": {
        "type": "object",
        "properties": {
          "system_name": {"type": "string"},
          "ai_capabilities": {"type": "string"}
